# ============================================================
# router-metrics-monitor configuration template
# Copy this file to .env and fill in your actual values:
#   Copy-Item .env.example .env
# .env is already ignored by .gitignore and will not be committed.
# ============================================================

# ---- Router SSH connection ----
ROUTER_HOST=192.168.1.1
ROUTER_USER=root
ROUTER_PASS=your_password_here

# Router SSH host key fingerprint (prevents man-in-the-middle attacks).
# How to obtain: run `plink -ssh root@192.168.1.1` once from the command line.
# On first connect it prints "... key fingerprint is: ssh-rsa 2048 SHA256:xxxx";
# put the SHA256:xxxx value here. Leave empty to auto-accept on first connect
# (slightly less secure).
ROUTER_HOSTKEY=

# ---- Collection parameters ----
# WAN interface name. PPPoE dial-up is usually pppoe-wan; DHCP/static is usually
# eth0 or wan. Use `ip route show default` and check the interface after `dev`.
WAN_IFACE=pppoe-wan

# Speed sampling interval (seconds): the script samples byte counts twice this
# far apart on the router to compute the rate.
SAMPLE_SECONDS=5

# Maximum number of points kept per monthly data file.
# Default is one collection per minute = 1440/day, about 44k points per month,
# so this is set to 45000.
MAX_POINTS=45000

# ---- Git push ----
# Remote branch (used by git-push.js)
GIT_BRANCH=main
